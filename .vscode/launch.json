{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug phonebook backend",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/part3/phonebook-backend/index.js",
      "cwd": "${workspaceFolder}/part3/phonebook-backend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug current Node.js file",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
